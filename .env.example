# Copy to .env to override defaults. Nothing here is required: the app boots
# unconfigured and you set operational config (LLM provider/model, feed
# metadata, connection URLs, admin password) at runtime in the Settings UI.
# The values below are the compose-friendly defaults baked into the code.

# ---------- Core (all optional; shown values are the code defaults) ----------
BASE_URL=http://localhost:8000
UI_BASE_URL=
DATA_DIR=/data
FIRECRAWL_URL=http://firecrawl:3002
# Optional bearer token for a Firecrawl instance behind auth (hosted API or a
# self-hosted deployment with a key). Leave blank for an open self-hosted server.
FIRECRAWL_API_KEY=
TTS_URL=http://tts-wrapper:8000
LLM_PROVIDER=openai-compatible
LLM_MODEL=
FEED_TITLE=Audicle
FEED_DESCRIPTION=
FEED_AUTHOR=
FEED_EMAIL=
FEED_ARTWORK_URL=

# ---------- LLM provider connection (UI-settable) ----------
# LLM_PROVIDER is one of: openai-compatible, anthropic, openrouter, ollama.
# openai-compatible: OPENAI_BASE_URL points at any OpenAI-compatible server
# (vLLM, LM Studio, Groq, ...); the UI lists models from {OPENAI_BASE_URL}/models.
OPENAI_BASE_URL=
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# openrouter: fixed base (https://openrouter.ai/api/v1); only the key is needed.
# OPENROUTER_API_KEY=
# ollama: openai-compatible against a local Ollama daemon.
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# ---------- Feed defaults ----------
FEED_LANGUAGE=en-us
FEED_CATEGORY=News
FEED_EXPLICIT=false

# ---------- LLM ----------
LLM_TEMPERATURE=0.7
# Per-call output cap. Cleanup runs the article in windows of
# LLM_CLEANUP_WINDOW_CHARS, so this only covers one window's output.
LLM_MAX_TOKENS=16000
# Cleanup window size (chars): long articles are split on paragraph boundaries,
# each window cleaned in its own LLM call, then concatenated -- so article
# length is never bottlenecked by the output cap.
LLM_CLEANUP_WINDOW_CHARS=12000
LLM_TIMEOUT_SECONDS=300
LLM_RETRY_COUNT=3

# ---------- Extraction ----------
FIRECRAWL_RETRY_COUNT=3
FIRECRAWL_BACKOFF_BASE_SECONDS=1
FIRECRAWL_TIMEOUT_SECONDS=30
MIN_EXTRACTION_CHARS=500
MIN_CLEANUP_CHARS=200
# Master switch for paywall bypass: when a matched host's direct scrape comes
# back below its teaser threshold, retry via a bypass strategy (Googlebot fetch,
# Freedium, or a custom reader-proxy). Configure the host list and default
# strategy in the Settings UI (or PUT /api/v1/source-fallbacks); a built-in
# Medium rule ships by default. Set false to always use the direct scrape.
EXTRACTION_FALLBACKS_ENABLED=true
# Scrape filtering so page chrome is dropped before the LLM sees it.
# FIRECRAWL_EXCLUDE_TAGS is a comma-separated list of HTML tags/selectors.
FIRECRAWL_ONLY_MAIN_CONTENT=true
FIRECRAWL_REMOVE_BASE64_IMAGES=true
FIRECRAWL_EXCLUDE_TAGS=nav,footer,header,aside

# ---------- Queue / HTTP ----------
QUEUE_POLL_INTERVAL_SECONDS=2
JOB_TIMEOUT_SECONDS=1800
WEB_WORKERS=2

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------- Retention ----------
# Episodes older than this many days are deleted by the daily sweep.
# 0 (or any value <= 0) disables the automatic sweep entirely (keep forever).
# The explicit wipe-everything action lives behind POST /api/v1/purge?confirm=true.
RETENTION_DAYS=90
RETENTION_SWEEP_HOUR_UTC=7
MIGRATION_BACKUP_RETENTION_DAYS=30

# ---------- RSS ----------
RSS_CACHE_MAX_AGE_SECONDS=300

# ---------- CORS ----------
CORS_ORIGINS=

# ---------- Limits ----------
MAX_PROMPT_LENGTH_BYTES=10240
MAX_CORRECTIONS_ENTRIES=500
# Apply the full base lexicon to every matching word on the text-only path
# (xtts/chatterbox). Only high-confidence respellings are applied so auto-derived
# entries can't regress words the model already says correctly.
LEXICON_AGGRESSIVE=true

# ---------- TTS wrapper ----------
TTS_LANGUAGE=en
TTS_DEVICE=cuda
# Engine: chatterbox (Resemble AI, text-only, the default going forward), xtts
# (legacy Coqui, text-only), or styletts2 (phoneme engine; honors curated IPA).
# Must match the wrapper image's build-arg TTS_BACKEND -- each engine is installed
# into its own image (their transformers pins conflict).
TTS_ENGINE=chatterbox
# Chatterbox-only generate knobs (ignored by xtts/styletts2). Defaults are a
# neutral straight read; raise CHATTERBOX_EXAGGERATION toward 1.0 for more
# expressive prosody. Output carries an inaudible Resemble PerTh watermark.
# CHATTERBOX_TEMPERATURE 0.5 (down from Turbo's 0.8) trims sampling variance that
# causes the same word to read right most times then wrong once. CHATTERBOX_SEED
# makes a chunk reproducible run-to-run; set 0 to disable (prior random behavior).
# Audio-QA regenerations override the seed per attempt so a bad take doesn't just
# reproduce; this is the baseline seed for first attempts.
CHATTERBOX_EXAGGERATION=0.0
CHATTERBOX_CFG_WEIGHT=0.0
CHATTERBOX_TEMPERATURE=0.5
CHATTERBOX_SEED=1234
# StyleTTS2-only (ignored by XTTS/Chatterbox): STYLETTS2_MODEL_PATH (blank =
# bundled default), STYLETTS2_PHONEMIZER_LANG=en-us
TTS_HTTP_TIMEOUT_SECONDS=120
TTS_RETRY_COUNT=3
TTS_REACHABILITY_GRACE_SECONDS=60
TTS_REACHABILITY_PROBE_TIMEOUT=10
XTTS_TEMPERATURE=0.60
XTTS_LENGTH_PENALTY=1.0
XTTS_REPETITION_PENALTY=2.0
XTTS_TOP_K=50
XTTS_TOP_P=0.85
# Speaker conditioning. Defaults match XTTS-v2's own, so these reproduce prior
# behavior. To steady prosody and reduce pitch drift, raise XTTS_GPT_COND_LEN so
# more of a long (20-60s) reference clip shapes the speaker latent -- the default
# 6 uses only ~6s. Try 30 with a clean reference, then A/B by ear. Bump the chunk
# length alongside it; keep max_ref_length >= gpt_cond_len.
XTTS_GPT_COND_LEN=6
XTTS_GPT_COND_CHUNK_LEN=6
XTTS_MAX_REF_LENGTH=30
# Playback speed passed to inference. 1.0 is unchanged; values just under 1.0
# (e.g. 0.95) counter XTTS's tendency to speed up and raise pitch on long runs.
XTTS_SPEED=1.0
# Per-call character cap fed to XTTS inference. Kept under XTTS's ~250-char warn
# threshold; lower trims pitch drift, higher risks garbled segment ends.
XTTS_MAX_CHARS=200

# ---------- Chunking + audio (Phase 5) ----------
TTS_CHUNK_TARGET_WORDS=180
TTS_CHUNK_MAX_WORDS=220
TTS_CHUNK_MAX_CHARS=1100
TTS_CHUNK_SILENCE_MS=250
AUDIO_SILENCE_THRESHOLD=0.003
AUDIO_SILENCE_BUFFER_MS=5
LOUDNORM_TARGET_LUFS=-14
LOUDNORM_TRUE_PEAK_DB=-3
LOUDNORM_LRA=7
MP3_BITRATE=128k
MP3_SAMPLE_RATE=24000
MP3_CHANNELS=2
# Post-TTS audio QA: detect a chunk that came back as a flat drone / steady
# noise / repetition and regenerate it (Chatterbox is non-deterministic, so a
# re-gen usually recovers). Thresholds need empirical tuning; the scalar knobs
# are also operator-tunable at runtime. Set AUDIO_ANALYSIS_ENABLED=false to skip.
AUDIO_ANALYSIS_ENABLED=true
AUDIO_ANALYSIS_MAX_REGEN=2
AUDIO_ANALYSIS_FRAME_MS=25
AUDIO_ANALYSIS_HOP_MS=10
AUDIO_ANALYSIS_MIN_RMS_CV=0.35
AUDIO_ANALYSIS_MIN_CREST=3.0
AUDIO_ANALYSIS_MAX_ZCR=0.35
AUDIO_ANALYSIS_MAX_SILENT_FRACTION=0.85
AUDIO_ANALYSIS_WORDS_PER_SEC=2.7
AUDIO_ANALYSIS_DURATION_OVERHEAD_SECS=1.0
AUDIO_ANALYSIS_MAX_DURATION_RATIO=2.0
AUDIO_ANALYSIS_MIN_DURATION_RATIO=0.25

# ---------- Post-TTS ASR verification (optional, off by default) ----------
# A second quality gate on top of the audio analysis above. When on, the GPU
# tts-wrapper transcribes each produced chunk with faster-whisper and the backend
# compares that transcript to the text it asked the wrapper to speak. A high
# word-level divergence (dropped content, a hallucinated run, a leaked preamble)
# regenerates the chunk on the same AUDIO_ANALYSIS_MAX_REGEN budget. It adds
# per-chunk latency, so it is off unless you turn BOTH sides on.
#
# Backend side (decides whether to request and act on a transcript). These three
# are also runtime-overridable from the Settings page / PUT /api/v1/settings, so
# you can toggle the gate and tune it live without a restart; the values here are
# just the defaults:
WHISPER_VERIFY_ENABLED=false
WHISPER_DIVERGENCE_THRESHOLD=0.35   # 0..1; above this a chunk is regenerated
WHISPER_VERIFY_MIN_WORDS=8          # skip tiny chunks where ASR noise dominates
#
# Wrapper side (loads the model; must be on for the backend flag to do anything):
WHISPER_ENABLED=false
WHISPER_MODEL=base                  # tiny | base | small | medium | large-v3
# WHISPER_DEVICE and WHISPER_COMPUTE_TYPE default to the TTS device (cuda ->
# float16, cpu -> int8). Override only to pin a different ASR placement.
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16

# ---------- Artwork (Phase 6) ----------
ARTWORK_SIZE_PX=3000
ARTWORK_JPG_QUALITY=85
ARTWORK_FETCH_TIMEOUT_SECONDS=15
ARTWORK_MIN_SOURCE_PX=600
ARTWORK_MAX_DOWNLOAD_BYTES=26214400

# ---------- Auth ----------
# Auth is set up at runtime in the Settings UI, not via env vars. Set an admin
# password under Settings > Security; until then the app runs in open
# convenience mode (all admin endpoints accept unauthenticated requests) for a
# single-operator localhost install. The bcrypt hash lives in the DB.
#
# SESSION_SECRET_KEY is optional: when blank, a secret is auto-generated on
# first run and persisted to the DB so sessions survive restarts. Set it only
# to pin an explicit key (e.g. to share sessions across replicas).
SESSION_SECRET_KEY=

# Requires HTTPS for the session cookie. Default true (secure by default); set
# false only for plain-http localhost dev.
SESSION_COOKIE_SECURE=true

# Session cookie lifetime. Default is 14 days.
SESSION_COOKIE_MAX_AGE_SECONDS=1209600

# Lockout policy, keyed on client IP. 5 failed attempts opens a 15-minute
# window during which subsequent attempts return 423 Locked.
LOCKOUT_MAX_FAILED_ATTEMPTS=5
LOCKOUT_WINDOW_SECONDS=900

# Per-IP rate limit on /api/v1/auth/login. The slowapi limiter currently
# uses a hardcoded decorator value; the env var is advisory until the
# wiring is refactored to pull the limit at request time.
LOGIN_RATE_LIMIT=10/minute
